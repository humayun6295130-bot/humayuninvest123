# ==========================================
# Investment Platform - Environment Variables
# ==========================================
# 
# HOW TO USE:
# 1. Copy this file and rename it to .env.local
# 2. Replace the placeholder values with your actual Firebase credentials
# 3. For Vercel deployment, add these in Vercel Dashboard > Settings > Environment Variables
#
# ==========================================

# ------------------------------------------
# FIREBASE CONFIGURATION (Required)
# Get these from Firebase Console > Project Settings > General > Your Apps
# ------------------------------------------

NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://your_project_id-default-rtdb.firebaseio.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id

# ==========================================
# OPTIONAL: Analytics & Monitoring
# ==========================================

# Google Analytics (optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Sentry Error Tracking (optional)
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@yyy.ingest.sentry.io/zzz

# ==========================================
# FEATURE FLAGS (Optional)
# ==========================================

# Enable/disable features
# NEXT_PUBLIC_ENABLE_REFERRALS=true
# NEXT_PUBLIC_ENABLE_INVESTMENTS=true
# NEXT_PUBLIC_ENABLE_KYC=true

# ==========================================
# ADMIN SETTINGS
# ==========================================

# Admin email (auto-assigned admin role on registration)
# NEXT_PUBLIC_ADMIN_EMAIL=admin@example.com
