# ==========================================
# Investment Platform - Environment Variables
# ==========================================
# 
# HOW TO USE:
# 1. Copy this file and rename it to .env.local
# 2. Replace the placeholder values with your actual Firebase credentials
# 3. For Vercel deployment, add these in Vercel Dashboard > Settings > Environment Variables
#
# NOTE: For running cron scripts (daily-earnings-cron.cjs, setup-level-system.cjs, etc.)
# use the non-prefixed versions below (without NEXT_PUBLIC_)
#
# ==========================================

# ------------------------------------------
# FIREBASE CONFIGURATION (Required)
# Get these from Firebase Console > Project Settings > General > Your Apps
# ------------------------------------------

# For Next.js web app (use NEXT_PUBLIC_ prefix):
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://your_project_id-default-rtdb.firebaseio.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id

# For Node.js scripts (no prefix - same values as above):
FIREBASE_API_KEY=your_api_key_here
FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
FIREBASE_DATABASE_URL=https://your_project_id-default-rtdb.firebaseio.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_MEASUREMENT_ID=your_measurement_id

# ==========================================
# PLATFORM CONFIGURATION
# ==========================================

# Base URL for referral links and emails
NEXT_PUBLIC_BASE_URL=https://your-domain.com

# ==========================================
# OPTIONAL: Analytics & Monitoring
# ==========================================

# Google Analytics (optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Sentry Error Tracking (optional)
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@yyy.ingest.sentry.io/zzz

# ==========================================
# FEATURE FLAGS (Optional)
# ==========================================

# Enable/disable features
# NEXT_PUBLIC_ENABLE_REFERRALS=true
# NEXT_PUBLIC_ENABLE_INVESTMENTS=true
# NEXT_PUBLIC_ENABLE_KYC=true

# ==========================================
# TRON BLOCKCHAIN CONFIGURATION (Required for auto-verification)
# ==========================================

# TRONGRID API Key (Get from https://www.trongrid.io/)
NEXT_PUBLIC_TRONGRID_API_KEY=

# Admin Wallet Address (TRON TRC-20 USDT address for receiving payments)
# This is the address where users will send their USDT deposits
# WARNING: Replace with your actual wallet address in production!
NEXT_PUBLIC_ADMIN_WALLET_ADDRESS=

# Additional Wallet Addresses (Optional - leave empty if not used)
# NEXT_PUBLIC_ADMIN_ERC20_ADDRESS=
# NEXT_PUBLIC_ADMIN_BTC_ADDRESS=

# Minimum confirmations required for transaction verification (default: 19)
# NEXT_PUBLIC_MIN_CONFIRMATIONS=19

# USDT TRC-20 Contract Address (usually doesn't change)
# NEXT_PUBLIC_USDT_CONTRACT=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t

# ==========================================
# ADMIN SETTINGS
# ==========================================

# Admin email (auto-assigned admin role on registration)
# NEXT_PUBLIC_ADMIN_EMAIL=admin@example.com

# ==========================================
# BLOCKCHAIN FEATURE FLAGS
# ==========================================

# Enable automatic blockchain verification
# NEXT_PUBLIC_ENABLE_BLOCKCHAIN_VERIFICATION=true

# Enable double-spending check
# NEXT_PUBLIC_ENABLE_DOUBLE_SPEND_CHECK=true
