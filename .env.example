# ==========================================
# Investment Platform - Environment Variables
# ==========================================
# 
# HOW TO USE:
# 1. Copy this file and rename it to .env.local
# 2. Replace the placeholder values with your actual Firebase credentials
# 3. For Vercel deployment, add these in Vercel Dashboard > Settings > Environment Variables
#
# NOTE: For running cron scripts (daily-earnings-cron.cjs, setup-level-system.cjs, etc.)
# use the non-prefixed versions below (without NEXT_PUBLIC_)
#
# ==========================================

# ------------------------------------------
# FIREBASE CONFIGURATION (Required)
# Get these from Firebase Console > Project Settings > General > Your Apps
# ------------------------------------------

# For Next.js web app (use NEXT_PUBLIC_ prefix):
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://your_project_id-default-rtdb.firebaseio.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id

# For Node.js scripts (no prefix - same values as above):
FIREBASE_API_KEY=your_api_key_here
FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
FIREBASE_DATABASE_URL=https://your_project_id-default-rtdb.firebaseio.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_MEASUREMENT_ID=your_measurement_id

# ==========================================
# PLATFORM CONFIGURATION
# ==========================================

# Base URL for referral links and emails
NEXT_PUBLIC_BASE_URL=https://your-domain.com

# ==========================================
# OPTIONAL: Analytics & Monitoring
# ==========================================

# Google Analytics (optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Sentry Error Tracking (optional)
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@yyy.ingest.sentry.io/zzz

# ==========================================
# FEATURE FLAGS (Optional)
# ==========================================

# Enable/disable features
# NEXT_PUBLIC_ENABLE_REFERRALS=true
# NEXT_PUBLIC_ENABLE_INVESTMENTS=true
# NEXT_PUBLIC_ENABLE_KYC=true

# ==========================================
# TRON BLOCKCHAIN CONFIGURATION (Required for auto-verification)
# ==========================================

# TRONGRID API Key (Get from https://www.trongrid.io/)
NEXT_PUBLIC_TRONGRID_API_KEY=

# Admin Wallet Address (TRON TRC-20 USDT address for receiving payments)
# This is the address where users will send their USDT deposits
# WARNING: Replace with your actual wallet address in production!
NEXT_PUBLIC_ADMIN_WALLET_ADDRESS=

# Additional Wallet Addresses (Optional - leave empty if not used)
# NEXT_PUBLIC_ADMIN_ERC20_ADDRESS=
# NEXT_PUBLIC_ADMIN_BTC_ADDRESS=

# Minimum confirmations required for transaction verification (default: 19)
# NEXT_PUBLIC_MIN_CONFIRMATIONS=19

# ------------------------------------------
# NOWPayments (primary investment checkout — QR dialog)
# https://nowpayments.io — API key & IPN secret from dashboard; never expose in NEXT_PUBLIC_
# ------------------------------------------
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
# Pay currency (NOWPayments ticker). USDT on BNB Smart Chain = usdtbsc (NOT usdtbe20).
PAYMENT_CURRENCY=usdtbsc
# Public site URL (no trailing slash) — used to build ipn_callback_url. NOWPayments cannot POST to localhost; on local dev the app omits IPN and relies on polling.
# NEXT_PUBLIC_BASE_URL is also listed under PLATFORM CONFIGURATION above.
# Optional: full IPN URL override (public https), e.g. ngrok: https://xxxx.ngrok.io/api/nowpayments/ipn
# NOWPAYMENTS_IPN_CALLBACK_URL=
# Optional: try sending localhost IPN URL anyway (usually rejected by NOWPayments)
# NOWPAYMENTS_ALLOW_LOCAL_IPN=1

# ------------------------------------------
# BSC BEP20 USDT — legacy manual tx verification (POST /api/invest/verify-bsc-usdt) if used elsewhere
# Must be 0x + 40 hex (BNB Smart Chain). Not a TRON T... address.
# ------------------------------------------
NEXT_PUBLIC_BSC_ADMIN_WALLET_ADDRESS=
# Server-only (runtime on Vercel; preferred for API if NEXT_PUBLIC_* missing at build)
ADMIN_WALLET_ADDRESS=
BSC_ADMIN_WALLET_ADDRESS=
# Optional alias (same as ADMIN_WALLET_ADDRESS)
# PLATFORM_WALLET_ADDRESS=
# Optional explorer keys — only for tokentx / explorer receipt fallback (main path uses public BSC RPC, no key).
# You can set ONLY one of these:
# • ETHERSCAN_API_KEY — Etherscan API V2 (multichain); must include BSC (chain 56) on your plan: https://etherscan.io/apidashboard
# • BSCSCAN_API_KEY — optional alternative from https://bscscan.com/apis (free tier works for BSC tokentx); omit if you use Etherscan only.
# ETHERSCAN_API_KEY=
# BSCSCAN_API_KEY=
# Optional: custom BSC node for eth_getTransactionReceipt / eth_blockNumber
# BSC_RPC_URL=https://bsc-dataseed1.binance.org

# USDT TRC-20 Contract Address (usually doesn't change)
# NEXT_PUBLIC_USDT_CONTRACT=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t

# ==========================================
# ADMIN SETTINGS
# ==========================================

# Admin email (auto-assigned admin role on registration)
# NEXT_PUBLIC_ADMIN_EMAIL=admin@example.com

# ==========================================
# BLOCKCHAIN FEATURE FLAGS
# ==========================================

# Enable automatic blockchain verification
# NEXT_PUBLIC_ENABLE_BLOCKCHAIN_VERIFICATION=true

# Enable double-spending check
# NEXT_PUBLIC_ENABLE_DOUBLE_SPEND_CHECK=true
