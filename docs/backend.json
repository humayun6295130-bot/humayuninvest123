{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile information within the AscendFolio application.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "username": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string" },
        "currencyPreference": { "type": "string" },
        "balance": { "type": "number" },
        "activePlan": { "type": "string" },
        "isPublic": { "type": "boolean" },
        "bio": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "role"]
    },
    "Portfolio": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Portfolio",
      "type": "object",
      "description": "Represents a user's personal collection or grouping of investment holdings.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "userProfileId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "userProfileId"]
    },
    "Asset": {
      "properties": {
        "id": { "type": "string" },
        "portfolioId": { "type": "string" },
        "symbol": { "type": "string" },
        "assetType": { "type": "string" },
        "quantity": { "type": "number" },
        "averageCost": { "type": "number" },
        "currency": { "type": "string" },
        "purchaseDate": { "type": "string" }
      }
    },
    "Transaction": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Transaction",
      "type": "object",
      "description": "Represents a financial transaction (deposit or withdrawal).",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userDisplayName": { "type": "string" },
        "userEmail": { "type": "string" },
        "type": { "type": "string", "enum": ["deposit", "withdrawal"] },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "completed", "failed"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "proofUrl": { "type": "string" },
        "transactionHash": { "type": "string" }
      },
      "required": ["userId", "type", "amount", "status"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": { "entityName": "UserProfile" }
      },
      {
        "path": "/roles_admin/{userId}",
        "definition": { "entityName": "AdminRole" }
      },
      {
        "path": "/users/{userId}/portfolios/{portfolioId}",
        "definition": { "entityName": "Portfolio" }
      },
      {
        "path": "/users/{userId}/portfolios/{portfolioId}/assets/{assetId}",
        "definition": { "entityName": "Asset" }
      },
      {
        "path": "/transactions/{transactionId}",
        "definition": { "entityName": "Transaction" }
      },
      {
        "path": "/public_profiles/{username}",
        "definition": { "entityName": "UserProfile" }
      }
    ]
  }
}