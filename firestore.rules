rules_version = '2';

// Default: any signed-in user can read/write (matches client-side invest + referral flows).
// Tighten per collection (e.g. isAdmin(), user_id == request.auth.uid) before public hardening.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
