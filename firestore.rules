rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    match /roles_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if (isOwner(userId) && request.resource.data.id == userId) || isAdmin();
      allow update: if (isOwner(userId) && request.resource.data.id == userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /users/{userId}/portfolios/{portfolioId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /users/{userId}/portfolios/{portfolioId}/assets/{assetId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /transactions/{transactionId} {
      // Users can see their own transactions, Admins can see all.
      allow list: if isAdmin() || (isSignedIn() && request.query.limit <= 100);
      allow get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      
      // Users can create their own transaction requests.
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      
      // Only admins can update or delete transactions.
      allow update, delete: if isAdmin();
    }
    
    match /published_posts/{postId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /users/{userId}/draft_posts/{postId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }
  }
}