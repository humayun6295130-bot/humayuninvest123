/**
 * # Core Philosophy
 * This ruleset enforces a strict user-ownership model for private data and a
 * public-read, author-write model for shared content. It achieves security
 * and performance by physically separating private user data from public data
 * into different collections.
 *
 * # Data Structure
 * - Private user data (profiles, portfolios, assets, draft posts) is nested
 *   under `/users/{userId}`. Access to this entire data tree is controlled by
 *   matching the authenticated user's ID with the `userId` in the path.
 * - Public data (published posts, public profiles, categories, tags, price history) and
 *   operational data (transactions) are stored in top-level collections for efficient querying.
 *
 * # Key Security Decisions
 * - **Strict Ownership**: Users can only access data within their own
 *   `/users/{userId}` path or documents they own in root collections.
 * - **Admin Role**: An 'admin' role has elevated privileges, such as updating
 *   any user's profile, managing transactions, and writing to global content collections.
 * - **Limited User Listing**: Listing the entire `/users` collection is
 *   disallowed for regular users, but admins can list all users.
 * - **Centralized Transactions**: All transactions are in a single `/transactions`
 *   collection to allow admins to easily query for pending items. Rules
 *   ensure users can only read their own and admins can read/update all.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    //-------------------------------------------------------------------------
    // Helper Functions
    //-------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    //-------------------------------------------------------------------------
    // User Data Collections (/users/{userId}/**)
    //-------------------------------------------------------------------------

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin() || request.query.limit <= 1; 
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role && request.resource.data.balance == resource.data.balance) || isAdmin();
      allow delete: if isOwner(userId) || isAdmin();
    }

    match /users/{userId}/portfolios/{portfolioId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if (isExistingOwner(userId) || isAdmin()) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId) || isAdmin();
    }

    match /users/{userId}/portfolios/{portfolioId}/assets/{assetId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.portfolioId == portfolioId;
      allow update: if (isExistingOwner(userId) || isAdmin()) && request.resource.data.portfolioId == resource.data.portfolioId;
      allow delete: if isExistingOwner(userId) || isAdmin();
    }

    match /users/{userId}/draft_posts/{postId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.authorId == userId;
      allow update: if (isExistingOwner(userId) || isAdmin()) && request.resource.data.authorId == resource.data.authorId;
      allow delete: if isExistingOwner(userId) || isAdmin();
    }

    //-------------------------------------------------------------------------
    // Public & Shared Collections
    //-------------------------------------------------------------------------
    
    match /transactions/{transactionId} {
      // Users can only see their own transactions. Admins can see everything.
      // Use resource.data for get/list checks.
      allow get, list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      // Users can only create transactions for themselves.
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      // Only admins can update transaction status (e.g., from pending to completed).
      allow update: if isAdmin();
      // Transactions should generally not be deleted for audit purposes.
      allow delete: if false; 
    }

    match /public_profiles/{username} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow delete: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
    }

    match /published_posts/{postId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isOwner(resource.data.authorId) || isAdmin());
      allow delete: if isSignedIn() && (isOwner(resource.data.authorId) || isAdmin());
    }

    match /asset_price_history/{priceHistoryId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /content_categories/{categoryId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /content_tags/{tagId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
  }
}